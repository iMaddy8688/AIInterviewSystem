@page "/student/login"
@inject AuthService Auth
@inject NavigationManager Nav
@* Redirect if already logged in *@
@if (Auth.IsLoggedIn && Auth.Role == "Student")
{
    Nav.NavigateTo("/student/dashboard");
    return;
}

<div class="login-page">
    <div class="blob" style="width:450px;height:450px;background:#6366F1;top:-100px;left:-100px"></div>
    <div class="blob" style="width:350px;height:350px;background:#8B5CF6;bottom:-80px;right:-60px"></div>

    <div class="login-box">
        <div class="login-top">
            <div class="portal-tag tag-s">🎓 Student Portal</div>
            <div class="login-icon login-icon-s" style="font-size:28px">🎓</div>
            <div class="login-title">AI Interview System</div>
            <div class="login-sub">CDS Coding Institute — .NET Full Stack</div>
        </div>

        <div class="login-body">
            @if (ErrorMsg != null)
            {
                <div class="error-box">
                    ⚠️ @ErrorMsg
                </div>
            }

            <div class="fg">
                <label class="fl">Roll Number</label>
                <input class="fi"
                       placeholder="e.g. S001"
                       @bind="RollNumber"
                       @bind:event="oninput"
                       @onkeydown="HandleKey"
                       disabled="@Loading" />
            </div>

            <div class="fg">
                <label class="fl">Password</label>
                <input class="fi"
                       type="@(ShowPass ? "text" : "password")"
                       placeholder="••••••••"
                       @bind="Password"
                       @bind:event="oninput"
                       @onkeydown="HandleKey"
                       disabled="@Loading" />
                <div style="margin-top:5px;cursor:pointer;font-size:11px;
                            color:var(--t3);text-align:right"
                     @onclick="() => ShowPass = !ShowPass">
                    @(ShowPass ? "🙈 Hide" : "👁 Show") password
                </div>
            </div>

            <button class="login-btn login-btn-s"
                    @onclick="LoginAsync"
                    disabled="@Loading">
                @if (Loading)
                {
                    <span>Logging in…</span>
                }
                else
                {
                    <span>Login to Student Portal →</span>
                }
            </button>

            <div class="login-hint" style="margin-top:14px">
                Forgot password? Contact your instructor
            </div>

            @* Demo credentials hint *@
            <div style="margin-top:12px;padding:10px 12px;
                        background:var(--sbg);border-radius:var(--r);
                        border:1px solid var(--s1)">
                <div style="font-size:11px;font-weight:700;
                            color:var(--s3);margin-bottom:3px">
                    Demo Login
                </div>
                <div style="font-size:11px;color:var(--t2)">
                    Roll: <b style="color:var(--t1)">S001</b> &nbsp;
                    Pass: <b style="color:var(--t1)">pass123</b>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    string RollNumber = "";
    string Password = "";
    string? ErrorMsg;
    bool Loading;
    bool ShowPass;

    async Task LoginAsync()
    {
        // Validation
        if (string.IsNullOrWhiteSpace(RollNumber))
        {
            ErrorMsg = "Please enter your roll number.";
            return;
        }
        if (string.IsNullOrWhiteSpace(Password))
        {
            ErrorMsg = "Please enter your password.";
            return;
        }

        Loading = true;
        ErrorMsg = null;
        StateHasChanged();

        var (success, error) = await Auth.StudentLoginAsync(
            RollNumber.Trim(), Password);

        if (success)
        {
            Nav.NavigateTo("/student/dashboard");
        }
        else
        {
            ErrorMsg = error;
            Loading = false;
        }
    }

    async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoginAsync();
    }
}