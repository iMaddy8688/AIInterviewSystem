@page "/student/select-subjects"
@inject AuthService Auth
@inject ApiService Api
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn)
{
    Nav.NavigateTo("/student/login");
    return;
}

<div style="min-height:100vh;background:var(--root);
            padding:40px 20px;display:flex;
            justify-content:center;align-items:flex-start">

    <div style="width:100%;max-width:620px">

        @* Header *@
        <div style="text-align:center;margin-bottom:28px">
            <div style="font-size:44px;margin-bottom:10px">📚</div>
            <div style="font-size:22px;font-weight:800;color:var(--t1)">
                Select Your Subjects
            </div>
            <div style="font-size:13px;color:var(--t2);margin-top:6px;
                        line-height:1.6">
                Welcome, <b style="color:var(--s3)">@Auth.FullName</b>!
                <br />Choose the subjects you are studying.
                AI will prepare interview questions accordingly.
            </div>
        </div>

        @* Step indicator *@
        <div style="display:flex;align-items:center;
                    justify-content:center;gap:0;margin-bottom:28px">
            <div style="display:flex;align-items:center;gap:6px">
                <div style="width:26px;height:26px;border-radius:50%;
                            background:var(--green);display:flex;
                            align-items:center;justify-content:center;
                            font-size:12px;color:#fff;font-weight:800">✓</div>
                <span style="font-size:12px;color:var(--green);
                             font-weight:600">Registered</span>
            </div>
            <div style="width:50px;height:2px;
                        background:var(--s1);margin:0 8px"></div>
            <div style="display:flex;align-items:center;gap:6px">
                <div style="width:26px;height:26px;border-radius:50%;
                            background:var(--s1);display:flex;
                            align-items:center;justify-content:center;
                            font-size:12px;color:#fff;font-weight:800">2</div>
                <span style="font-size:12px;color:var(--s3);
                             font-weight:700">Select Subjects</span>
            </div>
            <div style="width:50px;height:2px;
                        background:var(--border2);margin:0 8px"></div>
            <div style="display:flex;align-items:center;gap:6px">
                <div style="width:26px;height:26px;border-radius:50%;
                            background:var(--card2);
                            border:1.5px solid var(--border2);
                            display:flex;align-items:center;
                            justify-content:center;
                            font-size:12px;color:var(--t3);
                            font-weight:800">3</div>
                <span style="font-size:12px;color:var(--t3)">
                    Dashboard
                </span>
            </div>
        </div>

        @* Error *@
        @if (ErrorMsg != null)
        {
            <div class="error-box" style="margin-bottom:16px">
                ⚠️ @ErrorMsg
            </div>
        }

        @* Loading *@
        @if (Loading)
        {
            <div style="text-align:center;padding:60px">
                <div class="spinner"></div>
                <div style="margin-top:14px;color:var(--t2);
                            font-size:13px">Loading subjects…</div>
            </div>
        }
        else
        {
            @* HR always included notice *@
            <div style="display:flex;align-items:center;gap:10px;
                        padding:12px 16px;
                        background:var(--green-bg);
                        border:1px solid var(--green);
                        border-radius:var(--r);margin-bottom:16px">
                <span style="font-size:20px">🤝</span>
                <div>
                    <div style="font-size:13px;font-weight:700;
                                color:var(--green)">
                        HR Round — Always Included
                    </div>
                    <div style="font-size:11px;color:#6EE7B7">
                        Behavioral & communication practice
                        for all students
                    </div>
                </div>
            </div>

            @* Subject Cards Grid *@
            <div style="display:grid;
                        grid-template-columns:1fr 1fr;
                        gap:12px;margin-bottom:20px">
                @foreach (var s in Subjects)
                {
                    var selected = SelectedIds
                        .Contains(s.SubjectCategoryId);

                    <div @onclick="() => Toggle(s.SubjectCategoryId)"
                         style="background:var(--card);
                                border:2px solid @(selected
                                    ? "var(--s1)" : "var(--border)");
                                border-radius:var(--rl);
                                padding:18px 18px 16px;
                                cursor:pointer;
                                transition:all .2s;
                                position:relative;
                                @(selected ? "box-shadow:0 0 0 3px #6366F118" : "")">

                        @* Checkbox *@
                        <div style="position:absolute;top:14px;right:14px;
                                    width:22px;height:22px;border-radius:50%;
                                    background:@(selected ? "var(--s1)" : "transparent");
                                    border:2px solid @(selected
                                        ? "var(--s1)" : "var(--border2)");
                                    display:flex;align-items:center;
                                    justify-content:center;
                                    font-size:11px;color:#fff;
                                    transition:all .15s">
                            @if (selected)
                            {<span>✓</span>}
                        </div>

                        <div style="font-size:30px;margin-bottom:10px">
                            @s.Icon
                        </div>
                        <div style="font-size:14px;font-weight:700;
                                    color:var(--t1);margin-bottom:4px">
                            @s.Name
                        </div>
                        <div style="font-size:12px;color:var(--t2);
                                    line-height:1.5">
                            @s.Description
                        </div>
                    </div>
                }
            </div>

            @* Selection count *@
            <div style="text-align:center;margin-bottom:16px;
                        font-size:13px">
                @if (SelectedIds.Any())
                {
                    <span style="color:var(--s3)">
                        ✓ @SelectedIds.Count
                        subject@(SelectedIds.Count > 1 ? "s" : "")
                        selected + HR Round
                    </span>
                }
                else
                {
                    <span style="color:var(--t3)">
                        Select at least 1 subject to continue
                    </span>
                }
            </div>

            @* Continue button *@
            <button @onclick="SaveAndContinue"
                    disabled="@(Saving || !SelectedIds.Any())"
                    style="width:100%;padding:13px;border:none;
                           border-radius:var(--r);
                           font-size:14px;font-weight:700;
                           font-family:var(--font);
                           cursor:@(!SelectedIds.Any() || Saving
                               ? "not-allowed" : "pointer");
                           transition:all .2s;
                           background:@(SelectedIds.Any()
                               ? "linear-gradient(135deg,var(--s1),#8B5CF6)"
                               : "var(--card2)");
                           color:@(SelectedIds.Any()
                               ? "#fff" : "var(--t3)")">
                @if (Saving)
                {
                    <span style="display:flex;align-items:center;
                                 justify-content:center;gap:8px">
                        <span style="width:16px;height:16px;
                                     border:2px solid #ffffff40;
                                     border-top-color:#fff;
                                     border-radius:50%;
                                     animation:spin .8s linear infinite;
                                     display:inline-block"></span>
                        Saving…
                    </span>
                }
                else
                {
                    <span>Continue to Dashboard →</span>
                }
            </button>

            <div style="text-align:center;margin-top:10px;
                        font-size:11px;color:var(--t3)">
                You can update subjects later from profile settings
            </div>
        }
    </div>
</div>

@code {
    List<SubjectCategoryDto> Subjects = [];
    HashSet<int> SelectedIds = [];
    bool Loading = true;
    bool Saving;
    string? ErrorMsg;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/student/login");
            return;
        }

        // Already enrolled → dashboard
        var has = await Api.HasEnrollmentAsync();
        if (has)
        {
            Nav.NavigateTo("/student/dashboard");
            return;
        }

        Subjects = await Api.GetSubjectCategoriesAsync();
        Loading = false;
    }

    void Toggle(int id)
    {
        if (SelectedIds.Contains(id)) SelectedIds.Remove(id);
        else SelectedIds.Add(id);
    }

    async Task SaveAndContinue()
    {
        if (!SelectedIds.Any())
        {
            ErrorMsg = "Please select at least one subject.";
            return;
        }

        Saving = true;
        ErrorMsg = null;
        StateHasChanged();

        var ok = await Api.EnrollSubjectsAsync(SelectedIds.ToList());

        if (ok)
            Nav.NavigateTo("/student/dashboard");
        else
        {
            ErrorMsg = "Could not save. Please try again.";
            Saving = false;
        }
    }
}