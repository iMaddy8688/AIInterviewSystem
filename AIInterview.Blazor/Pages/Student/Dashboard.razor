@page "/student/dashboard"
@inject AuthService Auth
@inject ApiService Api
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn)
{
    Nav.NavigateTo("/student/login");
    return;
}

@if (Loading)
{
    <div style="min-height:100vh;display:flex;align-items:center;
                justify-content:center;background:var(--root)">
        <div style="text-align:center">
            <div class="spinner"></div>
            <div style="margin-top:12px;color:var(--t2);font-size:13px">
                Loading your dashboard…
            </div>
        </div>
    </div>
    return;
}

<div class="layout">

    @* ── SIDEBAR ─────────────────────────────────────── *@
    <aside class="sidebar">
        <div class="sb-logo">
            <div class="sb-icon sb-icon-s">🎓</div>
            <div>
                <div class="sb-title">AIInterview</div>
                <div class="sb-sub">Student Portal</div>
            </div>
        </div>

        <nav class="sb-nav">
            <div class="sb-section">Main</div>
            <div class="ni on-s">
                <span class="ni-icon">🏠</span> Dashboard
            </div>

            @* Dynamic subjects from DB *@
            @foreach (var s in MySubjects)
            {
                <div class="ni"
                     @onclick="() => GoToInterview(s)">
                    <span class="ni-icon">@s.Icon</span>
                    @s.Name
                </div>
            }

            <div class="sb-section">Tools</div>
            <div class="ni"
                 @onclick='() => Nav.NavigateTo("/student/resume")'>
                <span class="ni-icon">📄</span> Resume Analysis
            </div>
            <div class="ni"
                 @onclick='() => Nav.NavigateTo("/student/roadmap")'>
                <span class="ni-icon">🗺️</span> Roadmap
            </div>
            <div class="ni"
                 @onclick='() => Nav.NavigateTo("/student/history")'>
                <span class="ni-icon">📊</span> History
                @if (History.Any())
                {
                    <span class="ni-badge">@History.Count</span>
                }
            </div>
        </nav>

        <div class="sb-footer">
            @* Profile card *@
            <div style="padding:12px;background:var(--card2);
                        border-radius:var(--rl);margin-bottom:10px;
                        border:1px solid var(--border)">
                <div style="display:flex;align-items:center;
                            gap:10px;margin-bottom:10px">
                    <div style="width:40px;height:40px;border-radius:50%;
                                background:linear-gradient(135deg,
                                    var(--s1),#8B5CF6);
                                display:flex;align-items:center;
                                justify-content:center;
                                font-size:14px;font-weight:800;
                                color:#fff;flex-shrink:0">
                        @Auth.Initials
                    </div>
                    <div style="flex:1;min-width:0">
                        <div style="font-size:13px;font-weight:700;
                                    color:var(--t1);white-space:nowrap;
                                    overflow:hidden;text-overflow:ellipsis">
                            @Auth.FullName
                        </div>
                        <div style="font-size:10px;color:var(--t3)">
                            @Auth.RollNumber · @Auth.Batch
                        </div>
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;
                            gap:6px">
                    <div style="background:var(--card);
                                border-radius:var(--r);
                                padding:7px;text-align:center;
                                border:1px solid var(--border)">
                        <div style="font-size:16px;font-weight:800;
                                    color:var(--s3)">
                            @TotalSessions
                        </div>
                        <div style="font-size:10px;color:var(--t3)">
                            Sessions
                        </div>
                    </div>
                    <div style="background:var(--card);
                                border-radius:var(--r);
                                padding:7px;text-align:center;
                                border:1px solid var(--border)">
                        <div style="font-size:16px;font-weight:800;
                                    color:@AvgScoreColor">
                            @AvgScore%
                        </div>
                        <div style="font-size:10px;color:var(--t3)">
                            Avg Score
                        </div>
                    </div>
                </div>
            </div>

            <div class="user-pill" @onclick="Logout">
                <div class="uav uav-s">@Auth.Initials</div>
                <div class="u-info">
                    <div class="u-name">Logout</div>
                    <div class="u-role">Click to sign out</div>
                </div>
                <span style="color:var(--t3);font-size:12px">→</span>
            </div>
        </div>
    </aside>

    @* ── MAIN ────────────────────────────────────────── *@
    <div class="main">
        <div class="topbar">
            <div class="tb-title">Dashboard</div>
            <div class="tb-r">
                <div style="font-size:12px;color:var(--t3)">
                    @DateTime.Now.ToString("dddd, dd MMM yyyy")
                </div>
                <button class="btn btn-ghost btn-sm"
                        @onclick='() => Nav.NavigateTo("/student/select-subjects")'>
                    ✏️ My Subjects
                </button>
            </div>
        </div>

        <div class="body">
            @* Welcome *@
            <div style="margin-bottom:20px">
                <div class="pg-title">Namaste, @FirstName! 👋</div>
                <div class="pg-sub">@WelcomeMessage</div>
            </div>

            @* Stats *@
            <div class="stats" style="margin-bottom:20px">
                <div class="stat">
                    <div class="stat-bar"
                         style="background:linear-gradient(90deg,
                                var(--s1),#8B5CF6)"></div>
                    <div class="stat-label">Total Sessions</div>
                    <div class="stat-val">@TotalSessions</div>
                    <div class="stat-ch">Completed interviews</div>
                </div>
                <div class="stat">
                    <div class="stat-bar"
                         style="background:var(--green)"></div>
                    <div class="stat-label">Average Score</div>
                    <div class="stat-val"
                         style="color:@AvgScoreColor">
                        @AvgScore%
                    </div>
                    <div class="stat-ch">
                        @(AvgScore >= 70 ? "Great performance!" :
                          AvgScore >= 50 ? "Keep practicing" :
                          TotalSessions > 0 ? "Needs improvement" :
                          "Give your first interview!")
                    </div>
                </div>
                <div class="stat">
                    <div class="stat-bar"
                         style="background:var(--amber)"></div>
                    <div class="stat-label">Best Round</div>
                    <div class="stat-val"
                         style="font-size:16px;line-height:1.3">
                        @(BestRound ?? "—")
                    </div>
                    <div class="stat-ch">
                        @(BestScore > 0 ? $"Score: {BestScore}%" :
                          "No sessions yet")
                    </div>
                </div>
                <div class="stat">
                    <div class="stat-bar"
                         style="background:var(--red)"></div>
                    <div class="stat-label">Weak Area</div>
                    <div class="stat-val"
                         style="font-size:16px;line-height:1.3">
                        @(WeakRound ?? "—")
                    </div>
                    <div class="stat-ch"
                         style="color:@(WeakRound != null ?
                             "var(--red)" : "var(--t3)")">
                        @(WeakScore > 0 ? $"Score: {WeakScore}%" :
                          "Practice more!")
                    </div>
                </div>
            </div>

            @* How it works *@
            <div class="how" style="margin-bottom:20px">
                <div class="h-step">
                    <div class="h-num h-num-s">1</div>
                    <div class="h-text">🔊 AI asks question</div>
                </div>
                <div class="h-arr">›</div>
                <div class="h-step">
                    <div class="h-num h-num-s">2</div>
                    <div class="h-text">🎤 You speak answer</div>
                </div>
                <div class="h-arr">›</div>
                <div class="h-step">
                    <div class="h-num h-num-s">3</div>
                    <div class="h-text">📹 Webcam monitors</div>
                </div>
                <div class="h-arr">›</div>
                <div class="h-step">
                    <div class="h-num h-num-s">4</div>
                    <div class="h-text">🤖 Gemini evaluates</div>
                </div>
                <div class="h-arr">›</div>
                <div class="h-step">
                    <div class="h-num h-num-s">5</div>
                    <div class="h-text">📈 Score + feedback</div>
                </div>
            </div>

            @* Interview Rounds — Dynamic *@
            <div style="font-size:13px;font-weight:700;
                        color:var(--t1);margin-bottom:10px">
                Your Interview Rounds
            </div>

            @if (!MySubjects.Any())
            {
                <div style="text-align:center;padding:32px;
                            background:var(--card);
                            border:1px solid var(--border);
                            border-radius:var(--rl);
                            margin-bottom:20px">
                    <div style="font-size:32px;margin-bottom:10px">📚</div>
                    <div style="font-size:14px;color:var(--t2)">
                        No subjects selected yet.
                    </div>
                    <button class="btn btn-s btn-sm"
                            style="margin-top:12px"
                            @onclick='() => Nav.NavigateTo(
                                "/student/select-subjects")'>
                        Select Subjects
                    </button>
                </div>
            }
            else
            {
                <div class="modules" style="margin-bottom:20px">
                    @foreach (var s in MySubjects)
                    {
                        var last = GetLastScore(s.Name);
                        var isBest = BestRound != null &&
                            s.Name.Contains(BestRound,
                            StringComparison.OrdinalIgnoreCase);
                        var isWeak = WeakRound != null &&
                            s.Name.Contains(WeakRound,
                            StringComparison.OrdinalIgnoreCase);

                        <div class="mod mod-s"
                             @onclick="() => GoToInterview(s)"
                             style="@(isWeak ?
                                 "border-color:var(--red);" : "")
                                @(isBest ?
                                 "border-color:var(--green);" : "")">
                            <div class="mod-icon"
                                 style="background:var(--card2)">
                                @s.Icon
                            </div>
                            <div class="mod-name">@s.Name</div>
                            <div class="mod-desc">@s.Description</div>
                            <div style="display:flex;align-items:center;
                                        justify-content:space-between;
                                        margin-top:auto">
                                @if (isWeak)
                                {
                                    <span class="badge b-red">
                                        Weak area
                                    </span>
                                }
                                else if (isBest)
                                {
                                    <span class="badge b-green">
                                        Best round
                                    </span>
                                }
                                else
                                {
                                    <span class="badge b-gray">
                                        Practice
                                    </span>
                                }
                                @if (last > 0)
                                {
                                    <span style="font-size:11px;
                                                 color:@GetScoreColor(last)">
                                        Last: @last%
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @* Bottom row *@
            <div class="two">

                @* Recent sessions *@
                <div class="card">
                    <div style="display:flex;justify-content:space-between;
                                align-items:center;margin-bottom:14px">
                        <div style="font-size:14px;font-weight:700">
                            My Recent Sessions
                        </div>
                        <button class="btn btn-ghost btn-xs"
                                @onclick='() => Nav.NavigateTo(
                                    "/student/history")'>
                            View all
                        </button>
                    </div>

                    @if (!History.Any())
                    {
                        <div style="text-align:center;padding:28px 0;
                                    color:var(--t3)">
                            <div style="font-size:32px;margin-bottom:8px">
                                🎤
                            </div>
                            <div style="font-size:13px">
                                No sessions yet.
                                <br />Start your first interview!
                            </div>
                        </div>
                    }
                    else
                    {
                        @foreach (var h in History.Take(4))
                        {
                            <div style="display:flex;align-items:center;
                                        gap:10px;padding:10px 0;
                                        border-bottom:1px solid var(--border)">
                                <div style="width:8px;height:8px;
                                            border-radius:50%;flex-shrink:0;
                                            background:@GetScoreColor(h.TotalScore)">
                                </div>
                                <div style="flex:1">
                                    <div style="font-size:13px;
                                                color:var(--t1);
                                                font-weight:500">
                                        @GetIcon(h.RoundType) @h.RoundType
                                        @if (h.CheatFlagged)
                                        {
                                            <span class="badge b-amber"
                                                  style="margin-left:6px;
                                                         font-size:10px">
                                                ⚠️ Flagged
                                            </span>
                                        }
                                    </div>
                                    <div style="font-size:11px;
                                                color:var(--t3)">
                                        @h.Level ·
                                        @h.CompletedAt.ToString(
                                            "dd MMM, hh:mm tt")
                                    </div>
                                </div>
                                <span class="badge @GetBadge(h.TotalScore)">
                                    @h.TotalScore%
                                </span>
                            </div>
                        }
                    }
                </div>

                @* Quick actions + tip *@
                <div style="display:flex;flex-direction:column;gap:12px">
                    <div class="card">
                        <div style="font-size:14px;font-weight:700;
                                    margin-bottom:12px">
                            Quick Actions
                        </div>

                        <div @onclick='() => Nav.NavigateTo("/student/resume")'
                             style="display:flex;align-items:center;gap:11px;
                                    padding:10px;border-radius:var(--r);
                                    background:var(--card2);cursor:pointer;
                                    margin-bottom:6px;transition:background .15s">
                            <div style="width:34px;height:34px;
                                        border-radius:9px;background:var(--sbg);
                                        display:flex;align-items:center;
                                        justify-content:center;font-size:16px">
                                📄
                            </div>
                            <div>
                                <div style="font-size:13px;font-weight:600;
                                            color:var(--t1)">
                                    Upload Resume
                                </div>
                                <div style="font-size:11px;color:var(--t3)">
                                    AI skills & gap analysis
                                </div>
                            </div>
                            <span style="margin-left:auto;color:var(--t3)">
                                ›
                            </span>
                        </div>

                        <div @onclick='() => Nav.NavigateTo("/student/roadmap")'
                             style="display:flex;align-items:center;gap:11px;
                                    padding:10px;border-radius:var(--r);
                                    background:var(--card2);cursor:pointer;
                                    transition:background .15s">
                            <div style="width:34px;height:34px;
                                        border-radius:9px;
                                        background:var(--green-bg);
                                        display:flex;align-items:center;
                                        justify-content:center;font-size:16px">
                                🗺️
                            </div>
                            <div>
                                <div style="font-size:13px;font-weight:600;
                                            color:var(--t1)">
                                    Learning Roadmap
                                </div>
                                <div style="font-size:11px;color:var(--t3)">
                                    AI 4-week study plan
                                </div>
                            </div>
                            <span style="margin-left:auto;color:var(--t3)">
                                ›
                            </span>
                        </div>
                    </div>

                    @* AI Tip *@
                    <div style="padding:14px;background:var(--sbg);
                                border-radius:var(--rl);
                                border:1px solid var(--s1)">
                        <div style="font-size:11px;font-weight:700;
                                    color:var(--s3);margin-bottom:5px">
                            💡 AI Tip for You
                        </div>
                        <div style="font-size:12px;color:var(--t2);
                                    line-height:1.6">
                            @AiTip
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@code {
    bool Loading = true;

    List<MyEnrollmentDto> MySubjects = [];
    List<SessionHistoryDto> History = [];

    int TotalSessions;
    int AvgScore;
    string? BestRound;
    int BestScore;
    string? WeakRound;
    int WeakScore;

    string FirstName => Auth.FullName?
        .Split(' ').FirstOrDefault() ?? "Student";

    string AvgScoreColor =>
        AvgScore >= 70 ? "var(--green)" :
        AvgScore >= 50 ? "var(--amber)" :
        AvgScore > 0 ? "var(--red)" : "var(--t1)";

    string WelcomeMessage =>
        TotalSessions == 0
        ? "Welcome! Start your first interview to begin your practice journey."
        : $"You have completed {TotalSessions} sessions. Keep it up!";

    string AiTip =>
        WeakRound != null
        ? $"Your {WeakRound} score is {WeakScore}%. Focus on this — check the Learning Roadmap for a study plan."
        : TotalSessions == 0
        ? "Start with the HR Round first — it builds confidence for technical rounds."
        : "Consistency is key! Try to practice at least one round daily.";

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/student/login");
            return;
        }

        // Load in parallel
        var subjectsTask = Api.GetMySubjectsAsync();
        var historyTask = Api.GetMyHistoryAsync();

        await Task.WhenAll(subjectsTask, historyTask);

        MySubjects = subjectsTask.Result;
        History = historyTask.Result;

        // Calculate stats
        TotalSessions = History.Count;

        if (History.Any())
        {
            AvgScore = (int)History.Average(h => h.TotalScore);

            var best = History
                .OrderByDescending(h => h.TotalScore).First();
            BestRound = best.RoundType;
            BestScore = best.TotalScore;

            var weak = History
                .GroupBy(h => h.RoundType)
                .Select(g => new
                {
                    Round = g.Key,
                    Avg = (int)g.Average(h => h.TotalScore)
                })
                .Where(x => x.Avg < 65)
                .OrderBy(x => x.Avg)
                .FirstOrDefault();

            if (weak != null)
            {
                WeakRound = weak.Round;
                WeakScore = weak.Avg;
            }
        }

        Loading = false;
    }

    void GoToInterview(MyEnrollmentDto s)
    {
        var name = s.Name.Replace(" ", "");
        Nav.NavigateTo(
            $"/student/interview/{s.SubjectCategoryId}/{name}");
    }

    int GetLastScore(string roundName) =>
        History
        .Where(h => h.RoundType.Equals(
            roundName.Replace(" ", ""),
            StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(h => h.CompletedAt)
        .FirstOrDefault()?.TotalScore ?? 0;

    string GetScoreColor(int s) =>
        s >= 70 ? "var(--green)" :
        s >= 50 ? "var(--amber)" : "var(--red)";

    string GetBadge(int s) =>
        s >= 70 ? "b-green" :
        s >= 50 ? "b-amber" : "b-red";

    string GetIcon(string r) => r switch
    {
        "HR" => "🤝",
        "DotNet" => "⚡",
        "SQL" => "🗄️",
        "Coding" => "💻",
        "Java" => "☕",
        "Python" => "🐍",
        "React" => "⚛️",
        _ => "🎤"
    };

    void Logout()
    {
        Auth.Logout();
        Nav.NavigateTo("/student/login");
    }
}